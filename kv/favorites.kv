<FavoritesScreen>:
    name: 'favorites'
    FloatLayout:
        FitImage:
            source: app.background_source
            size_hint: 1, 1
        MDBoxLayout:
            orientation: 'vertical'

            MDTopAppBar:
                type: "small"
                theme_bg_color: "Custom"
                md_bg_color: (0,0,0,0)
                MDTopAppBarLeadingButtonContainer:
                    MDActionTopAppBarButton:
                        icon: "menu"
                        theme_icon_color: "Custom"
                        icon_color: "#ffffff"
                        on_release: app.nav_drawer.set_state("toggle")
                MDTopAppBarTitle:
                    text: "Избранное"
                    halign: "center"
                    theme_text_color: "Custom"
                    text_color: "#ffffff"
                MDTopAppBarTrailingButtonContainer:
                    id: rec_top_bar_trail
                    MDActionTopAppBarButton:
                        icon: "logout"
                        theme_icon_color: "Custom"
                        icon_color: "#ffffff"
                        on_release: app.logout()


            MDBoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: "8dp"
                spacing: "8dp"
                MDTextField:
                    id: search_field
                    mode: "outlined"
                    size_hint_y: None
                    height: "48dp"
                    padding: "8dp"
                    # Кастомные цвета
                    theme_bg_color: "Custom"
                    md_bg_color: (0.2, 0.2, 0.2, 0.8)   # фон поля
                    text_color_normal: (1, 1, 1, 1)      # цвет текста в обычном состоянии
                    text_color_focus: (1, 1, 1, 1)       # цвет текста при фокусе
                    line_color_normal: (0.7, 0.7, 0.7, 0.5)   # цвет обводки обычный
                    line_color_focus: (0.25, 0.62, 0.63, 1)   # цвет обводки при фокусе
                    on_text: root.on_search_text(self.text)
                    # Дочерние виджеты
                    MDTextFieldLeadingIcon:
                        icon: "magnify"
                        theme_icon_color: "Custom"
                        icon_color_normal: (0.9, 0.9, 0.9, 0.7)
                        icon_color_focus: (0.8, 0.8, 0.8, 1)
                    MDTextFieldHintText:
                        text: "Поиск игры..."
                        theme_text_color: "Custom"
                        text_color_normal: (0.9, 0.9, 0.9, 0.7)
                        text_color_focus: (0.8, 0.8, 0.8, 1)
                MDLabel:
                    text: "Жанры:"
                    theme_text_color: "Custom"
                    text_color: "#ffffff"
                    size_hint_y: None
                    height: self.texture_size[1]
                MDScrollView:
                    size_hint_y: None
                    height: "56dp"
                    do_scroll_x: True
                    do_scroll_y: False
                    MDBoxLayout:
                        id: genres_chips
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: "48dp"
                        spacing: "8dp"
                        padding: "8dp"
                        adaptive_width: True
                MDLabel:
                    text: "Платформы:"
                    theme_text_color: "Custom"
                    text_color: "#ffffff"
                    size_hint_y: None
                    height: self.texture_size[1]
                MDScrollView:
                    size_hint_y: None
                    height: "56dp"
                    do_scroll_x: True
                    do_scroll_y: False
                    MDBoxLayout:
                        id: platforms_chips
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: "48dp"
                        spacing: "8dp"
                        padding: "8dp"
                        adaptive_width: True

            MDScrollView:
                MDStackLayout:
                    id: favorites_list
                    adaptive_height: True
                    spacing: dp(5)
                    padding: dp(5)