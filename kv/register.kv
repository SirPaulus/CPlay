<RegisterScreen>:
    name: 'register'
    FloatLayout:
        FitImage:
            source: './assets/background.png'
            size_hint: 1, 1
        MDAnchorLayout:
            MDBoxLayout:
                orientation: 'vertical'
                spacing: dp(20)
                padding: dp(32)
                adaptive_height: True
                pos_hint: {'center_y': 0.5}
                size_hint_x: None
                width: dp(450)

                FitImage:
                    source: './assets/cplay.png'
                    size_hint: 0.65, None
                    height: dp(50)
                    fit_mode: "fill"
                    pos_hint: {"center_x": 0.5}

                MDLabel:
                    text: "Ваш личный проводник в мир игровой индустрии"
                    color: "#2ed5fa"
                    font_style: "Title"
                    role: "large"
                    size_hint_y: None
                    adaptive_height: True
                    halign: "center"

                Widget:
                    size_hint_y: None
                    height: "50dp"   # нужный отступ

                MDLabel:
                    text: "Регистрация"
                    color: "#ffffff"
                    font_style: "Display"
                    role: 'small'
                    halign: "center"
                    size_hint_y: None
                    height: self.texture_size[1]

                MDTextField:
                    id: username
                    mode: "filled"
                    size_hint_x: 0.8
                    pos_hint: {'center_x': 0.5}

                    MDTextFieldHintText:
                        text: "Имя пользователя"

                MDTextField:
                    id: password
                    mode: "filled"
                    password: True
                    size_hint_x: 0.8
                    pos_hint: {'center_x': 0.5}

                    MDTextFieldHintText:
                        text: "Пароль"

                MDTextField:
                    id: confirm
                    mode: "filled"
                    password: True
                    size_hint_x: 0.8
                    pos_hint: {'center_x': 0.5}

                    MDTextFieldHintText:
                        text: "Подтверждение пароля"

                MDButton:
                    style: 'filled'
                    size_hint_x: 0.5
                    pos_hint: {'center_x': 0.5}
                    on_release: root.try_register()
                    theme_bg_color: "Custom"
                    md_bg_color: (.18, .84, .98, 0.6)
                    MDButtonText:
                        text: "Зарегистрироваться"
                        color: "#ffffff"

                MDButton:
                    style: 'text'
                    pos_hint: {'center_x': 0.5}
                    on_release: root.go_to_login()
                    MDButtonText:
                        text: "Уже есть аккаунт? Войти"
                        theme_text_color: "Custom"
                        text_color: (.18, .84, .98, 0.6)