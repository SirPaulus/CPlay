<AdminScreen>:
    md_bg_color: self.theme_cls.backgroundColor
    name: 'admin'
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            type: "small"
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    on_release: app.back_to_games()
            MDTopAppBarTitle:
                text: "Редактирование игр"
                halign: "center"

        MDScrollView:
            MDStackLayout:
                id: games_list
                adaptive_height: True
                spacing: dp(5)
                padding: dp(5)